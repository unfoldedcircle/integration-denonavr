#: intg-denonavr/driver.py:448
msgid "Control your Denon or Marantz AVRs with Remote Two/3."
msgstr "Contrôler Denon ou Marantz AVRs avec Remote Two/3."

#: intg-denonavr/setup_flow.py:57
msgid "Integration setup"
msgstr "Configuration de l'intégration"

#: intg-denonavr/setup_flow.py:61
msgid "Setup process"
msgstr "Installation"

#: intg-denonavr/setup_flow.py:65
msgid "The integration discovers Denon and Marantz Receivers on the network."
msgstr "Cette intégration trouvera des AVR Denon et Marantz dans le réseau."

#: intg-denonavr/setup_flow.py:69
msgid "Please note that this integration can take 2-4s before it's ready to send commands after the remote starts or wakes up."
msgstr "Veuillez noter qu’après la mise en marche ou la sortie de veille de la télécommande, il faut attendre 2 à 4 secondes avant qu’elle puisse envoyer des commandes."

#: intg-denonavr/setup_flow.py:73
msgid "Please see our support article for requirements, features and restrictions."
msgstr "Consulte [l’article de support](https://support.unfoldedcircle.com/hc/en-us/articles/19480446994844) pour connaître les exigences, les fonctionnalités prises en charge et les restrictions."

#: intg-denonavr/setup_flow.py:85
msgid "Setup mode"
msgstr "Installation"

#: intg-denonavr/setup_flow.py:93
msgid "Leave blank to use auto-discovery and click _Next_."
msgstr "Laissez le champ vide pour utiliser la découverte automatique et cliquez sur _Suivant_."

#: intg-denonavr/setup_flow.py:95
msgid "The device must be on the same network as the remote."
msgstr "L'appareil doit être sur le même réseau que la télécommande."

#: intg-denonavr/setup_flow.py:102
msgid "Manual IP address or hostname"
msgstr "Adresse IP manuelle ou nom d'hôte"

#: intg-denonavr/setup_flow.py:112
msgid "Please note:"
msgstr "Veuillez noter:"

#: intg-denonavr/setup_flow.py:116
msgid "Using telnet provides realtime updates for many values but certain receivers allow a single connection only!"
msgstr "L'utilisation de Telnet fournit des mises à jour en temps réel pour de nombreuses valeurs, mais certains amplificateurs ne permettent qu'une seule connexion ! Avec ce paramètre, d'autres applications ou systèmes ne peuvent plus fonctionner."

#: intg-denonavr/setup_flow.py:200
msgid "Add a new device"
msgstr "Ajouter un nouvel appareil"

#: intg-denonavr/setup_flow.py:211
msgid "Configure selected device"
msgstr "Configurer l'appareil sélectionné"

#: intg-denonavr/setup_flow.py:218
msgid "Delete selected device"
msgstr "Supprimer l'appareil sélectionné"

#: intg-denonavr/setup_flow.py:225
